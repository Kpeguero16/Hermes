          "text": "Extract calendar events from the document.\n\nReturn ONLY raw JSON.\n\nDo NOT include markdown formatting.\nDo NOT include ```json or ``` blocks.\nDo NOT include any explanation.\n\nFormat:\n[\n  {\n    \"title\": \"string\",\n    \"date\": \"YYYY-MM-DD or null\",\n    \"start_time\": \"HH:MM or null\",\n    \"end_time\": \"HH:MM or null\",\n    \"status\": \"confirmed | cancelled | postponed | null\",\n    \"notes\": \"string\"\n  }\n]\n\nRules:\n- Timezone is America/New_York (Eastern Time Zone). All times should be interpreted in this timezone.\n- If no time → leave null\n- If start time is provided but the end time is missing, make the event 1 hour long\n- If no date → leave null\n- Be fuzzy and extract best guesses",
          "inputType": "binary",
          "simplify": false,
          "options": {}
        },
        "type": "@n8n/n8n-nodes-langchain.googleGemini",
        "typeVersion": 1.2,
        "position": [
          -928,
          192
        ],
        "id": "f7d94422-e9b6-41ce-bbb2-aaed291fb415",
        "name": "Analyze document",
        "credentials": {
          "googlePalmApi": {
            "id": "2kUNacrQ9rZDOtud",
            "name": "Hermes main billing"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "const raw = $input.first().json.candidates[0].content.parts[0].text;\n\n// Strip markdown code fences if Gemini wraps output in ```json ... ```\nconst cleaned = raw.replace(/^```json\\s*|```$/gm, \"\").trim();\nconst events = JSON.parse(cleaned);\n\nconst TIMEZONE = \"America/New_York\";\n\nfunction getEasternOffset(dateStr, timeStr) {\n  // Create a date in UTC and check what offset NY would be at that moment\n  const dt = new Date(`${dateStr}T${timeStr}:00Z`);\n  \n  // Use Intl to determine what time NY thinks it is at this UTC moment\n  const nyTime = new Intl.DateTimeFormat(\"en-US\", {\n    timeZone: TIMEZONE,\n    year: \"numeric\", month: \"2-digit\", day: \"2-digit\",\n    hour: \"2-digit\", minute: \"2-digit\", second: \"2-digit\",\n    hour12: false\n  }).formatToParts(dt);\n\n  const get = type => nyTime.find(p => p.type === type).value;\n  const nyUTC = new Date(`${get(\"year\")}-${get(\"month\")}-${get(\"day\")}T${get(\"hour\") === \"24\" ? \"00\" : get(\"hour\")}:${get(\"minute\")}:${get(\"second\")}Z`);\n\n  const offsetMinutes = (nyUTC - dt) / 60000;\n  const sign = offsetMinutes >= 0 ? \"+\" : \"-\";\n  const abs = Math.abs(offsetMinutes);\n  const hh = String(Math.floor(abs / 60)).padStart(2, \"0\");\n  const mm = String(abs % 60).padStart(2, \"0\");\n  return `${sign}${hh}:${mm}`;\n}\n\nfunction toNYISO(date, time) {\n  if (!time) return null;\n  const offset = getEasternOffset(date, time);\n  return `${date}T${time}:00${offset}`;\n}\n\nreturn events.map(event => {\n  const isAllDay = !event.start_time && !event.end_time;\n  return {\n    json: {\n      ...event,\n      all_day: isAllDay,\n      start_time: isAllDay ? null : toNYISO(event.date, event.start_time),\n      end_time:   isAllDay ? null : toNYISO(event.date, event.end_time),\n      timezone: TIMEZONE\n    }\n  };\n});"
        },
