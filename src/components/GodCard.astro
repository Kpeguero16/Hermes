---
const attrs = [
  "Messenger of the gods — swift & reliable",
  "Patron of communication & coordination",
  "Guide who clears the path forward",
  "Always working — never sleeps",
];
---

<div class="bg-navy-card border-gold/20 relative overflow-hidden rounded-2xl border p-10 text-center">
  <div
    class="bg-gold/10 border-gold/40 mx-auto mb-6 flex h-[100px] w-[100px] items-center justify-center rounded-full border-2 text-5xl"
    aria-hidden="true"
  >
    ⚡
  </div>
  <p class="font-display text-gold text-5xl tracking-[4px]">HermeΣ</p>
  <p class="font-serif text-cream-dim mt-1 italic">God of Messages, Speed & Commerce</p>
  <div class="bg-gold/20 my-6 h-px" aria-hidden="true"></div>
  <ul class="flex flex-col gap-3 text-left">
    {
      attrs.map((a) => (
        <li class="text-cream-dim flex items-center gap-3 text-[13px]">
          <span class="bg-gold h-1.5 w-1.5 shrink-0 rounded-full" aria-hidden="true" />
          {a}
        </li>
      ))
    }
  </ul>
</div>
