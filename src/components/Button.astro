---
interface Props {
  href: string;
  variant?: "primary" | "ghost";
  class?: string;
}

const { href, variant = "primary", class: className = "" } = Astro.props;

const base =
  "inline-block rounded-full px-8 py-3.5 text-[15px] font-semibold tracking-wide transition-all duration-200";
const variants = {
  primary: "bg-gold text-navy hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(201,168,76,0.3)]",
  ghost: "border border-gold/40 text-gold hover:bg-gold/10 hover:-translate-y-0.5",
};
---

<a href={href} class={`${base} ${variants[variant]} ${className}`}><slot /></a>
