---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
---

<BaseLayout title="Page Not Found — HermeΣ" index={false}>
  <section class="bg-grid flex min-h-[70vh] flex-col items-center justify-center px-6 py-24 text-center md:px-12">
    <p class="font-display text-gold/20 text-[clamp(120px,25vw,220px)] leading-none tracking-[8px]">404</p>
    <h1 class="font-display -mt-4 text-[clamp(32px,5vw,52px)] leading-none tracking-[3px] text-white">
      Even the messenger god <span class="text-gold">gets lost.</span>
    </h1>
    <p class="font-serif text-cream-dim mt-5 max-w-md text-lg font-light italic">
      This page doesn't exist — but the path home is clear.
    </p>
    <div class="mt-10">
      <Button href="/">Back to Home</Button>
    </div>
  </section>
</BaseLayout>
